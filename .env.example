# API Keys for BoardPay Services
# Copy this file to .env and fill in your actual API keys

# Google Generative AI (Gemini 2.5 Flash for OCR)
# Get your key from: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (Llama 3.1 for AI Chat)
# Get your key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Optional: Django Debug and Development Settings
DEBUG=True
SECRET_KEY=your-secret-key-here

# Optional: CORS Settings (for development)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Optional: Database (if not using SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/boardpay
